# PostgreSQL connection string.
# Docker (default): postgresql://sentinel:sentinel@localhost:5432/sentinel?sslmode=disable
# Neon/Supabase cloud: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel?sslmode=disable

# AI provider API key. Leave empty to use the built-in Mock AI (works offline).
DEEPSEEK_API_KEY=

# NextAuth v5 — JWT session signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=dev-secret-change-in-production-abc123

# Public URL for NextAuth callbacks.
NEXTAUTH_URL=http://localhost:3000
